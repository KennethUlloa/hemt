# ── Server ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret
API_BASE_URL=http://localhost:5000

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_BACKEND: sqlite (default) | postgres
DATABASE_BACKEND=sqlite

# SQLite: path relative to instance/ folder
# DATABASE_URL=sqlite:///emailtrap.db

# Postgres: full connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/emailtrap

# ── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_BACKEND: local (default) | s3
STORAGE_BACKEND=local

# Local storage path
STORAGE_PATH=attachments

# S3 storage (requires pip install boto3)
# S3_BUCKET_NAME=emailtrap
# S3_REGION=us-east-1
# S3_PREFIX=attachments
